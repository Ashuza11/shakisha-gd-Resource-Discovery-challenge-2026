# Shakisha — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API key (required for AI features)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Data directory (optional — defaults to data/sample)
# To use the full dataset: unzip data/full-data.zip -d data/full
# then set this to: data/full
HACKATHON_DATA_DIR=data/full
